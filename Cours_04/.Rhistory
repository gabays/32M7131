str(x)
cat(x$lemma[1], "", file = filename)
for(i in 2:length(x$token_id)){
if(x$sentence_id[i] != x$sentence_id[i-1])
cat("\n", file = filename, append = T)
if(is.na(x$lemma[i]))
next
cat(x$lemma[i], "", file = filename, append = T)
}
